{
    "manifest_version": 3,
    "name": "Image Rotator",
    "version": "1.0.0",
    "description": "Double-click an image in a new tab to rotate it 90°",
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "match_origin_as_fallback": true,
        "js": ["content.js"],
        "run_at": "document_idle"
      }
    ]
  }